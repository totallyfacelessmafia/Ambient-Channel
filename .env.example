# AmbiHub environment — copy this to .env.local and fill in real values.
# .env.local is gitignored. Env vars take precedence over config.json, and this
# is how secrets get injected in cloud hosting later.

# ── Stripe (billing) ──  keys: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_ / pk_test_) for setup. Switch to live only at launch.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Filled in automatically by: python dashboard/stripe_setup.py --apply --write
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# ── Email (veto-window + failure notifications) ──
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxx
EMAIL_FROM=AmbiHub <notify@ambihub.ai>
APP_BASE_URL=http://localhost:5000
